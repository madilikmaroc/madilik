# App (use https://madilik.ma in production — no trailing slash; used for metadata, cookies, emails, image URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Storage
SUPABASE_URL=https://yhescktfdngyispqjbvt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Database (Prisma + PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/store?schema=public"

# Admin authentication (iron-session)
# SESSION_SECRET must be at least 32 characters
SESSION_SECRET=your-secure-random-string-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override for strict callback matching (must exactly match Google Console)
# GOOGLE_OAUTH_REDIRECT_URI=https://madilik.ma/api/auth/google/callback

# Google Translate API (optional – enables auto-translation of product content)
# GOOGLE_TRANSLATE_API_KEY=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
