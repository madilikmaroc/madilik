# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# User uploads (keep folder structure via .gitkeep, ignore actual uploaded files)
/public/uploads/products/*
!/public/uploads/products/.gitkeep
/public/uploads/banners/*
!/public/uploads/banners/.gitkeep
/public/uploads/categories/*
!/public/uploads/categories/.gitkeep
/public/uploads/reviews/*
!/public/uploads/reviews/.gitkeep

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
